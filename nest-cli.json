{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "builder": "swc",
        "deleteOutDir": true,
        "assets": [
            {
                "include": "**/*.jsx",
                "outDir": "dist"
            }
        ],
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true,
                    "controllerKeyOfComment": "summary"
                }
            }
        ]
    }
}
