{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "builder": "swc",
        "deleteOutDir": true,
        "assets": [{ "include": "**/*.html", "watchAssets": true }],
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true,
                    "controllerKeyOfComment": "summary"
                }
            }
        ]
    }
}
