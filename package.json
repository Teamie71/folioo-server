{
    "name": "folioo-server",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "echo 'export default async () => ({});' > src/metadata.ts",
        "build": "nest build --type-check",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "db:status": "supabase status",
        "db:push": "supabase db push",
        "db:pull": "supabase db pull",
        "db:diff": "supabase db diff",
        "db:migration:new": "supabase migration new",
        "db:link:dev": "supabase link --project-ref agmeiukuhrgqkmqsrxad",
        "db:link:prod": "supabase link --project-ref shzioyeqkhwuckqorevc",
        "start": "nest start --type-check",
        "start:dev": "nest start --type-check --watch",
        "start:debug": "nest start --type-check --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prepare": "node -e \"if (require('fs').existsSync('.git')) { require('child_process').execSync('husky', {stdio: 'inherit'}) }\""
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.2.3",
        "@nestjs/typeorm": "^11.0.0",
        "@sentry/nestjs": "^10.36.0",
        "axios": "^1.13.5",
        "busboy": "^1.6.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "cookie-parser": "^1.4.7",
        "express-basic-auth": "^1.2.1",
        "ioredis": "^5.9.2",
        "ms": "^2.1.3",
        "openai": "^6.22.0",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0",
        "passport-jwt": "^4.0.1",
        "passport-kakao": "^1.0.1",
        "passport-naver-v2": "^2.0.8",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.28",
        "typeorm-naming-strategies": "^4.1.0",
        "typeorm-transactional": "^0.5.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@swc/cli": "^0.7.9",
        "@swc/core": "^1.15.3",
        "@types/busboy": "^1.5.4",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/ms": "^2.1.0",
        "@types/multer": "^1.4.11",
        "@types/node": "^22.10.7",
        "@types/passport-google-oauth20": "^2.0.16",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-kakao": "^1.0.3",
        "@types/passport-oauth2": "^1.8.0",
        "@types/supertest": "^6.0.2",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^16.0.0",
        "husky": "^9.1.7",
        "jest": "^30.0.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md}": "prettier --write"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "moduleNameMapper": {
            "^src/(.*)$": "<rootDir>/$1"
        },
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
